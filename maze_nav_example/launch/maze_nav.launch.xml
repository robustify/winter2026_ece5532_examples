<?xml version="1.0"?>
<launch>
  <let name="nav2_params_file" value="$(find-pkg-share maze_nav_example)/config/nav2_params.yaml"/>

  <!-- Drive control node to convert Twist command into wheel speeds -->
  <node pkg="maze_nav_example" exec="drive_control.py" name="drive_control" output="screen">
    <param name="use_sim_time" value="true"/>
    <remap from="cmd_vel" to="cmd_vel_smoothed" />
  </node>

  <!-- Aid SLAM by integrating wheel speeds and publishing TF from odom to base_footprint -->
  <node pkg="dead_reckoning_odom" exec="dead_reckoning_odom" name="dead_reckoning" output="screen">
    <param name="use_sim_time" value="true"/>
    <param name="parent_frame" value="odom"/>
    <param name="child_frame"  value="base_footprint"/>
    <remap from="twist" to="/roundbot/twist"/>
  </node>

  <!-- Build a map of the maze with SLAM, loading an existing one, if available -->
  <node pkg="slam_toolbox" exec="async_slam_toolbox_node" name="slam_toolbox" output="screen">
    <param name="use_sim_time" value="true"/>
    <param from="$(find-pkg-share maze_nav_example)/config/slam_toolbox_params.yaml"/>
    <param name="mode" value="localization"/>
    <param name="map_file_name" value="$(find-pkg-share maze_nav_example)/map"/>
  </node>

  <!-- Manage SLAM lifecycle node's state machine -->
  <node pkg="nav2_lifecycle_manager" exec="lifecycle_manager" name="lifecycle_manager_localization" output="screen">
    <param name="use_sim_time" value="true"/>
    <param name="autostart"    value="true"/>
    <param name="node_names" value="[slam_toolbox]"/>
  </node>

  <!-- Navigation stack controller -->
  <node pkg="nav2_controller" exec="controller_server" output="screen">
    <param from="$(var nav2_params_file)"/>
    <param name="use_sim_time" value="true"/>
  </node>

  <!-- Navigation stack global planner -->
  <node pkg="nav2_planner" exec="planner_server" output="screen">
    <param from="$(var nav2_params_file)"/>
    <param name="use_sim_time" value="true"/>
  </node>

  <!-- Navigation stack fallback behaviors -->
  <node pkg="nav2_behaviors" exec="behavior_server" output="screen">
    <param from="$(var nav2_params_file)"/>
    <param name="use_sim_time" value="true"/>
  </node>

  <!-- Action server that implements goal navigation behavior tree -->
  <node pkg="nav2_bt_navigator" exec="bt_navigator" output="screen">
    <param from="$(var nav2_params_file)"/>
    <param name="use_sim_time" value="true"/>
  </node>

  <!-- Smooth velocities generated by planner before passing them to drive control -->
  <node pkg="nav2_velocity_smoother" exec="velocity_smoother" output="screen">
    <param from="$(var nav2_params_file)"/>
    <param name="use_sim_time" value="true"/>
  </node>

  <!-- Module to sequence multiple goals consecutively -->
  <node pkg="nav2_waypoint_follower" exec="waypoint_follower" output="screen">
    <param from="$(var nav2_params_file)"/>
    <param name="use_sim_time" value="true"/>
  </node>

  <!-- Manage navigation stack lifecycle nodes' state machines -->
  <node pkg="nav2_lifecycle_manager" exec="lifecycle_manager" name="lifecycle_manager_navigation" output="screen">
    <param name="use_sim_time" value="true"/>
    <param name="autostart"    value="true"/>
    <param name="node_names" value="[controller_server, planner_server, behavior_server, bt_navigator, velocity_smoother, waypoint_follower]"/>
  </node>

  <!-- Gazebo Simulation -->
  <include file="$(find-pkg-share ece5532_gazebo)/launch/gazebo_bringup.launch.py">
    <arg name="robot_sdf_file" value="$(find-pkg-share roundbot_description)/models/roundbot/model.sdf"/>
    <arg name="world_sdf_file" value="$(find-pkg-share maze_nav_example)/worlds/maze_world.sdf"/>
    <arg name="gz_bridge_file" value="$(find-pkg-share roundbot_gazebo)/config/ros_gz_bridge.yaml"/>
    <arg name="start_paused"   value="false"/>
    <arg name="headless"       value="false"/>
    <arg name="verbose"        value="false"/>
  </include>

  <!-- Visualize everything in RViz -->
  <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen" args="-d $(find-pkg-share maze_nav_example)/rviz/maze_nav_example.rviz">
    <param name="use_sim_time" value="true"/>
  </node>

</launch>
